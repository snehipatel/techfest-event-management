generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FACULTY_COORDINATOR
  CLUB_COORDINATOR
  TEAM_LEAD
  VOLUNTEER
  CAMPUS_AMBASSADOR
  STUDENT
}

enum TeamRole {
  TEAM_LEAD
  VOLUNTEER
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

model User {
  id                String           @id @default(uuid())
  name              String
  email             String           @unique
  password          String
  role              Role
  referralCode      String?          @unique
  createdAt         DateTime         @default(now())
  documentsUploaded Document[]
  documentAccess    DocumentAccess[]

  // 🔥 HIERARCHY
  reportsToId  String?
  reportsTo    User?   @relation("UserHierarchy", fields: [reportsToId], references: [id])
  subordinates User[]  @relation("UserHierarchy")

  registrations     Registration[]
  tasksAssignedToMe Task[]         @relation("AssignedTo")
  tasksAssignedByMe Task[]         @relation("AssignedBy")
  teams             TeamMember[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
}

model Event {
  id              String   @id @default(uuid())
  title           String
  description     String
  location        String?
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int
  createdAt       DateTime @default(now())

  registrations Registration[]
  tasks         Task[]
  teams         Team[]
}

model Team {
  id        String   @id @default(uuid())
  name      String
  eventId   String
  createdAt DateTime @default(now())

  event         Event          @relation(fields: [eventId], references: [id])
  members       TeamMember[]
  documents     Document[]
  registrations Registration[]
}

model TeamMember {
  id     String   @id @default(uuid())
  teamId String
  userId String
  role   TeamRole // TEAM_LEAD or VOLUNTEER

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model Document {
  id         String   @id @default(uuid())
  title      String
  fileUrl    String
  uploadedBy String
  teamId     String?
  createdAt  DateTime @default(now())

  uploader User             @relation(fields: [uploadedBy], references: [id])
  team     Team?            @relation(fields: [teamId], references: [id])
  access   DocumentAccess[]
}

model DocumentAccess {
  id         String @id @default(uuid())
  documentId String
  userId     String

  document Document @relation(fields: [documentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([documentId, userId])
}

model Registration {
  id        String             @id @default(uuid())
  userId    String
  eventId   String
  teamId    String?
  status    RegistrationStatus @default(PENDING)
  createdAt DateTime           @default(now())

  user    User     @relation(fields: [userId], references: [id])
  event   Event    @relation(fields: [eventId], references: [id])
  team    Team?    @relation(fields: [teamId], references: [id])
  payment Payment?
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  deadline    DateTime
  status      TaskStatus @default(TODO)

  eventId      String
  assignedToId String
  assignedById String
  completedAt  DateTime?

  event Event @relation(fields: [eventId], references: [id])

  assignedTo User @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy User @relation("AssignedBy", fields: [assignedById], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Payment {
  id             String   @id @default(uuid())
  registrationId String   @unique
  amount         Float
  status         String
  transactionId  String?
  createdAt      DateTime @default(now())

  registration Registration @relation(fields: [registrationId], references: [id])
}
